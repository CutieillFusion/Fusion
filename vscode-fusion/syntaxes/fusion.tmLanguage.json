{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "source.fusion",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#extern-lib" },
    { "include": "#import-lib" },
    { "include": "#field-access" },
    { "include": "#numbers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign", "match": "#.*$" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape", "match": "\\\\." }
          ]
        }
      ]
    },
    "extern-lib": {
      "patterns": [
        {
          "name": "meta.extern.fusion",
          "match": "\\b(extern)\\s+(lib)\\s+",
          "captures": {
            "1": { "name": "keyword.control" },
            "2": { "name": "storage.type" }
          }
        }
      ]
    },
    "import-lib": {
      "patterns": [
        {
          "name": "meta.import.fusion",
          "match": "\\b(import)\\s+(lib)\\s+",
          "captures": {
            "1": { "name": "keyword.control" },
            "2": { "name": "storage.type" }
          }
        }
      ]
    },
    "field-access": {
      "patterns": [
        {
          "name": "variable.other.member.fusion",
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.member" }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer", "match": "\\b\\d+\\b" }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "keyword.operator", "match": "->" },
        { "name": "punctuation.separator.dot", "match": "\\." },
        { "name": "punctuation.definition.group.begin", "match": "\\(" },
        { "name": "punctuation.definition.group.end", "match": "\\)" },
        { "name": "punctuation.definition.block.begin", "match": "\\{" },
        { "name": "punctuation.definition.block.end", "match": "\\}" },
        { "name": "punctuation.definition.bracket.begin", "match": "\\[" },
        { "name": "punctuation.definition.bracket.end", "match": "\\]" },
        { "name": "punctuation.separator.comma", "match": "," },
        { "name": "punctuation.terminator.statement", "match": ";" },
        { "name": "punctuation.separator.colon", "match": ":" },
        { "name": "keyword.operator.assignment", "match": "=" },
        { "name": "keyword.operator.arithmetic", "match": "\\+|\\-|\\*|/" },
        { "name": "keyword.operator.comparison", "match": "==|!=|<=|>=|<|>" }
      ]
    }
  }
}
